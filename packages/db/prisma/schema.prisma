generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model LatestTrend {
  id        String   @id @default(cuid())
  month     Int
  date      String   // YYYY-MM-DD (daily cache key)
  context   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, date])
}

model GenerationJob {
  id           String   @id @default(cuid())
  status       String   @default("pending") // pending | generating | done | failed
  errorMessage String?
  postId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 1件 = 1投稿スロット（朝/昼/夜）
model Post {
  id          String    @id @default(cuid())
  slot        String    // "morning" | "noon" | "evening"
  scheduledAt DateTime  // 予定投稿日時 (JST)
  theme       String    // コンテンツテーマ key
  themeName   String    // 表示名 (英語)
  imagePrompt String    // Pollo AI 用プロンプト
  tweetText           String    // ツイート本文 (英語)
  japaneseTranslation String    @default("") // 管理者用日本語訳
  imagePath           String?   // アップロード済みファイルパス (画像 or 動画)
  mediaType           String    @default("image") // "image" | "video"
  status      String    @default("draft") // draft | ready | posted | skipped
  generationConditions String?   // JSON: {situation,color,shade,pattern,expression,weather,freeText}
  tweetId     String?   // 投稿後の Tweet ID
  postedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
