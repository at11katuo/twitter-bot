# Twitter API v2 (Developer Portal → Project → App → Keys and tokens)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Anthropic (tweet text generation)
ANTHROPIC_API_KEY=

# Gemini (image scene + tweet generation)
GEMINI_API_KEY=

# fal.ai (image generation)
FAL_KEY=

# OpenRouter (trend summarization via LLM)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Tavily (web search for trend collection — optional)
TAVILY_API_KEY=

# Research API (internal Docker: http://research-api:8787, local dev: http://localhost:8787)
RESEARCH_API_URL=http://research-api:8787

# Database
DATABASE_URL=file:/app/data/hana.db

# Dashboard basic auth
DASHBOARD_BASIC_USER=admin
DASHBOARD_BASIC_PASS=changeme

# Image storage path (inside container)
IMAGE_DIR=/app/data/images

NODE_ENV=production
LOG_LEVEL=info
